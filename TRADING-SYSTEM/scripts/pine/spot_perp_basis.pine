//@version=5
// Спот/Перп БАЗИС как Z-осциллятор (центрирован на 0, фикс. бэнды ±1/±2/±3).
// ВЕШАТЬ НА ЧИСТЫЙ ГРАФИК ПЕРПА: BYBIT:ENAUSDT.P  (ОДИН символ, НЕ отношение!)
// Спот задаётся в инпуте. Базис% = (перп/спот − 1)×100; Z = (базис−μ)/σ.
// |Z|>2 = выброс (вход на схождение). Z≈0 = у среднего (центр сетки).
indicator("Спот/Перп базис — Z", shorttitle="basis Z", overlay=false, precision=2)

spotSym = input.symbol("BYBIT:ENAUSDT", "Спот-символ (нога B)")
N       = input.int(200, "Окно μ/σ (баров)", minval=20)
showPct = input.bool(false, "Показать базис% вместо Z")

perp = close
spot = request.security(spotSym, timeframe.period, close)

basis = (perp / spot - 1) * 100.0
mu  = ta.sma(basis, N)
sd  = ta.stdev(basis, N)
z   = sd != 0 ? (basis - mu) / sd : 0.0

val = showPct ? basis : z
zero = showPct ? mu : 0.0

// толстая линия, цвет по знаку Z
col = z > 2 ? color.red : z < -2 ? color.lime : z > 0 ? #e3933c : #39d0d8
plot(val, "значение", color=col, linewidth=3)

// фикс бэнды (для Z) или μ±σ (для %)
b1 = showPct ? mu + sd  : 1.0
b1n= showPct ? mu - sd  : -1.0
b2 = showPct ? mu + 2*sd: 2.0
b2n= showPct ? mu - 2*sd: -2.0
b3 = showPct ? mu + 3*sd: 3.0
b3n= showPct ? mu - 3*sd: -3.0
hline(zero, "центр", color=color.new(color.gray, 0), linestyle=hline.style_solid)
p1 =plot(b1 , "+1", color=color.new(color.gray,50), style=plot.style_linebr)
p1n=plot(b1n, "-1", color=color.new(color.gray,50), style=plot.style_linebr)
p2 =plot(b2 , "+2", color=color.new(color.red,40),  style=plot.style_linebr)
p2n=plot(b2n, "-2", color=color.new(color.green,40), style=plot.style_linebr)
p3 =plot(b3 , "+3", color=color.new(color.red,70),  style=plot.style_linebr)
p3n=plot(b3n, "-3", color=color.new(color.green,70), style=plot.style_linebr)
fill(p2, p3,  color=color.new(color.red,90),   title="зона перегрева")
fill(p2n,p3n, color=color.new(color.green,90),  title="зона продавленности")

// табличка
var table t = table.new(position.top_right, 2, 4, border_width=1, bgcolor=color.new(color.black,20))
if barstate.islast
    table.cell(t,0,0,"базис%",text_color=color.gray,text_size=size.small)
    table.cell(t,1,0,str.tostring(basis,"#.####")+"%",text_color=#39d0d8,text_size=size.small)
    table.cell(t,0,1,"μ",text_color=color.gray,text_size=size.small)
    table.cell(t,1,1,str.tostring(mu,"#.####")+"%",text_size=size.small)
    table.cell(t,0,2,"σ",text_color=color.gray,text_size=size.small)
    table.cell(t,1,2,str.tostring(sd,"#.####"),text_size=size.small)
    table.cell(t,0,3,"Z",text_color=color.gray,text_size=size.small)
    zc = math.abs(z)>2 ? color.red : math.abs(z)>1 ? color.orange : color.lime
    table.cell(t,1,3,str.tostring(z,"#.##"),text_color=zc,text_size=size.normal)

alertcondition(ta.crossover(z, 2),  "Z > +2", "Перп перегрет к споту")
alertcondition(ta.crossunder(z, -2), "Z < -2", "Перп продавлен к споту")
